# Supabase (Carely 전용 신규 프로젝트)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
# service-role 키는 서버 전용(크론 등 시스템 작업). 절대 클라이언트에 노출 금지.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Web Push (VAPID) — `npx web-push generate-vapid-keys` 로 1회 생성
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:noreply@carely.app

# 15분 크론 엔드포인트 보호용 Bearer 토큰 (Vercel cron 이 Authorization 헤더로 전송)
CRON_SECRET=

# (선택) 푸시 실패 시 이메일 폴백
RESEND_API_KEY=
